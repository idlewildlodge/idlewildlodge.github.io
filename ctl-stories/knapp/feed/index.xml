]]></description>
										<content:encoded><![CDATA[<div data-parent="true" class="vc_row row-container" id="row-unique-2"><div class="row col-no-gutter no-top-padding no-bottom-padding no-h-padding full-width row-parent"><div class="wpb_row row-inner"><div class="wpb_column pos-top pos-center align_left column_parent col-lg-12 no-internal-gutter"><div class="uncol style-light shift_y_neg_half"  ><div class="uncoltable"><div class="uncell no-block-padding" ><div class="uncont"><div class="uncode_text_column alpha-anim animate_when_almost_visible" ><h4><strong><div class="vc_acf vc_txt_align_left field_62d3df9341435">The Knapps Partner with Rannells on the Sawmill</div></strong></h4>
<div class="vc_acf vc_txt_align_left field_62cbafef995f0">John Rannells is mentioned as being a co-owner of the Knapp sawmill.</div>
</div></div></div></div></div></div>

<script id="script-row-unique-2" data-row="script-row-unique-2" type="text/javascript" class="vc_controls">UNCODE.initRow(document.getElementById("row-unique-2"));</script></div></div></div>




<div data-parent="true" class="vc_row row-container" id="row-unique-3"><div class="row col-no-gutter no-top-padding no-bottom-padding no-h-padding full-width row-parent"><div class="wpb_row row-inner"><div class="wpb_column pos-top pos-center align_left column_parent col-lg-1/5 no-internal-gutter"><div class="uncol style-light"  ><div class="uncoltable"><div class="uncell no-block-padding" ><div class="uncont"><div class="uncode_text_column vc_custom_1658132744002 border-color-gyho-color left-t-right animate_when_almost_visible"  style="border-style: solid;margin-right: 10% ;margin-left: 10% ;border-top-width: 4px ;border-right-width: 0px ;border-bottom-width: 0px ;border-left-width: 0px ;padding-top: 10px ;"><div class="vc_acf vc_txt_align_left field_62cbb251e2350">-H Knapp has bought a onefourth interest in the saw mill run by Rannells and Knapp.</div>
</div><div class="uncode_text_column vc_custom_1658132966338 right-t-left animate_when_almost_visible"  style="margin-right: 10% ;margin-left: 10% ;"><p style="text-align: left;"><em><div class="vc_acf vc_txt_align_left field_62cbb29fe2351">Loveland Reporter - December 27th 1894</div></em></p>
</div><div class="uncode_text_column vc_custom_1617356820233 border-color-gyho-color right-t-left animate_when_almost_visible"  style="border-style: solid;margin-right: 10% ;margin-left: 10% ;border-top-width: 0px ;border-right-width: 0px ;border-bottom-width: 1px ;border-left-width: 0px ;"></div></div></div></div></div></div><script id="script-row-unique-3" data-row="script-row-unique-3" type="text/javascript" class="vc_controls">UNCODE.initRow(document.getElementById("row-unique-3"));</script></div></div></div>



