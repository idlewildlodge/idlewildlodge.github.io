										<content:encoded><![CDATA[<div data-parent="true" class="vc_row row-container" id="row-unique-16"><div class="row col-no-gutter no-top-padding no-bottom-padding no-h-padding full-width row-parent"><div class="wpb_row row-inner"><div class="wpb_column pos-top pos-center align_left column_parent col-lg-12 no-internal-gutter"><div class="uncol style-light shift_y_neg_half"  ><div class="uncoltable"><div class="uncell no-block-padding" ><div class="uncont"><div class="uncode_text_column alpha-anim animate_when_almost_visible" ><h4><strong><div class="vc_acf vc_txt_align_left field_62d3df9341435">Ella Van Bramer At Idlewild</div></strong></h4>
<div class="vc_acf vc_txt_align_left field_62cbafef995f0">Ella Van Bramer begins building a campground at present day Idlewild.</div>
</div></div></div></div></div></div>

<script id="script-row-unique-16" data-row="script-row-unique-16" type="text/javascript" class="vc_controls">UNCODE.initRow(document.getElementById("row-unique-16"));</script></div></div></div>



